{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 10,
  "height": 24,

  "modules-left": ["sway/workspaces"],
  "modules-center": [
    "clock",
    "privacy",
    "custom/weather"
  ],
  "modules-right": [
    "group/tray-expander",
    "network",
    "bluetooth",
    "pulseaudio",
    "memory",
    "cpu",
    "battery"
  ],

  "privacy": {
    "icon-size": 15,
    "ignore-monitor": false
  },
  "cpu": {
    "interval": 5,
    "format": "о«Ќ{usage}%",
    "on-click": "ttyasrt btop",
    "on-click-right": "alacritty"
  },
  "memory": {
    "interval": 5,
    "format": "оњ†{avail:0.1f}GiB",
    "tooltip-format": "{used:0.1f} / {total:0.1f}GiB RAM вЏЅ {swapUsed:0.1f} / {swapTotal:0.1f}GiB Swap",
    "on-click": "ttyasrt btop",
    "on-click-right": "alacritty"
  },
  "clock": {
    "format": "{:L%a, %d %B %H:%M}",
    "tooltip": false,
    "on-click-right": "ttyasrt peaclock"
  },
  "custom/weather": {
    "exec": "wttrbar --nerd --hide-conditions --custom-indicator 'п”ў {uvIndex} {ICON}{FeelsLikeC}'",
    "return-type": "json",
    "interval": 60,
    "tooltip": true,
    "on-click": "ttyasrt curl https://wttr.in"
  },
  "network": {
    "format-icons": ["у°¤Ї", "у°¤џ", "у°¤ў", "у°¤Ґ", "у°¤Ё"],
    "format": "{icon} {bandwidthTotalBytes}",
    "format-wifi": "{icon} {bandwidthTotalBytes}",
    "format-ethernet": "у°Ђ‚ {bandwidthTotalBytes}",
    "format-disconnected": "",
    "tooltip-format-wifi": "{essid} вЏЅ {frequency} GHz вЏЅ {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "Connected",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "ttyasrt impala"
  },
  "battery": {
    "format": "{icon}{capacity}%",
    "format-discharging": "{icon}{capacity}%",
    "format-charging": "{icon}{capacity}%",
    "format-icons": {
      "charging": ["у°‚„"],
      "default": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"]
    },
    "format-full": "у°‚„{capacity}%",
    "tooltip-format-discharging": "{time} Remaining вЏЅ {power:>1.0f}Wв†“вЏЅ {cycles} Cycles",
    "tooltip-format-charging": "{time} Until Full вЏЅ {power:>1.0f}Wв†“вЏЅ {cycles} Cycles",
    "interval": 5,
    "on-click": "ttyasrt powertop",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "",
    "format-off": "у°‚І",
    "format-disabled": "у°‚І",
    "format-connected": "у°‚±{device_battery_percentage}%",
    "format-no-controller": "",
    "tooltip-format": "{num_connections} Connected вЏЅ {device_alias}",
    "on-click": "ttyasrt bluetui"
  },
  "pulseaudio": {
    "format": "{icon}{volume}%",
    "on-click": "ttyasrt wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "{desc}",
    "scroll-step": 5,
    "format-muted": "о»Ё",
    "format-icons": {
      "headphone": "у±ЎЏ",
      "headset": "у±ЎЏ",
      "default": ["пЂ¦", "пЂ§", "пЂЁ "]
    }
  },
  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },
  "custom/expand-icon": {
    "format": "пѓ™",
    "tooltip": false,
    "on-scroll-up": "",
    "on-scroll-down": "",
    "on-scroll-left": "",
    "on-scroll-right": ""
  },
  "tray": {
    "icon-size": 14,
    "spacing": 10
  }
}
